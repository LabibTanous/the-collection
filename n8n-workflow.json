      "id": "wh-claim", "name": "Claim Webhook", "type": "n8n-nodes-base.webhook",
      "typeVersion": 1, "position": [180, 200]
    },
    {
      "parameters": { "httpMethod": "POST", "path": "waitlist", "responseMode": "responseNode", "options": {} },
      "id": "wh-waitlist", "name": "Waitlist Webhook", "type": "n8n-nodes-base.webhook",
      "typeVersion": 1, "position": [180, 420]
    },
    {
      "parameters": { "httpMethod": "POST", "path": "newsletter", "responseMode": "responseNode", "options": {} },
