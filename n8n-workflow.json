    {
      "parameters": { "httpMethod": "POST", "path": "ship", "responseMode": "responseNode", "options": {} },
      "id": "wh-ship", "name": "Ship Webhook", "type": "n8n-nodes-base.webhook",
      "typeVersion": 1, "position": [180, 820]
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "value": "YOUR_GOOGLE_SHEET_ID" },
        "sheetName": { "value": "Claims" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "timestamp": "={{ $json.timestamp || $now }}",
            "email": "={{ $json.email }}",
            "product": "={{ $json.product }}",
            "edition_no": "={{ $json.no }}",
            "key": "={{ $json.key }}"
          }
        }
      },
      "id": "sheet-claims", "name": "Log Claim → Sheet", "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4, "position": [420, 200]
    },
    {
      "parameters": {
        "url": "https://api.resend.com/emails",
        "method": "POST",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {},
        "bodyParametersUi": {
          "parameter": [
            { "name": "from", "value": "the Collection <noreply@thecollection.ae>" },
            { "name": "to", "value": "={{ $('Claim Webhook').item.json.email }}" },
            { "name": "subject", "value": "={{ 'No. ' + $('Claim Webhook').item.json.no + ' of 99 — reserved in your name' }}" },
            { "name": "html", "value": "=<p style=\"font-family:Georgia,serif;color:#1A2B40\">Your edition is held.</p><p style=\"font-family:Georgia,serif;color:#1A2B40\"><strong>{{ $('Claim Webhook').item.json.product }} — No. {{ $('Claim Webhook').item.json.no }} of 99</strong> is reserved in your name. We'll be in touch shortly.</p><p style=\"font-family:Georgia,serif;color:#6B82A0;font-size:13px\">the Collection — UAE numbered editions of 99</p>" }
          ]
        }
      },
      "id": "email-claim-confirm", "name": "Email — Claim Confirmation", "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4, "position": [660, 160]
    },
    {
      "parameters": {
        "conditions": {
          "number": [{ "value1": "={{ $('sheet-claims').item.json.rowNumber || 0 }}", "operation": "largerEqual", "value2": 90 }]
        }
      },
      "id": "if-lowstock", "name": "IF Low Stock (≥90)", "type": "n8n-nodes-base.if",
      "typeVersion": 1, "position": [660, 260]
    },
    {
      "parameters": {
        "url": "={{ $env.SLACK_WEBHOOK_URL }}",
        "method": "POST",
        "bodyParametersUi": {
          "parameter": [
            { "name": "text", "value": "=🔴 *Low stock alert* — {{ $('Claim Webhook').item.json.product }}: {{ $('sheet-claims').item.json.rowNumber }} of 99 claimed. Only {{ 99 - $('sheet-claims').item.json.rowNumber }} left." }
          ]
        }
      },
      "id": "slack-lowstock", "name": "Slack — Low Stock Alert", "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4, "position": [900, 220]
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={ \"ok\": true }", "options": {} },
      "id": "resp-claim", "name": "Respond Claim", "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1, "position": [900, 320]
    },
